# Environment Variables Template for HC-FrontEnd

# Copy this file to .env and update the values as needed

# API Base URL - Change this to your backend API URL
REACT_APP_API_URL=http://localhost:5000/api

# For production deployment
# REACT_APP_API_URL=https://api.yourhealthcareapp.com/api

# Optional: Application name and version
# REACT_APP_APP_NAME=MediCare
# REACT_APP_VERSION=1.0.0
